# =============================================================================
# Video Commerce Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Auth
SESSION_SECRET=generate-a-random-64-character-string-here
ACCESS_CODE=your-access-code-here

# Email (Resend)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=hello@yourdomain.com

# Media (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Admin (seeded on first startup)
ADMIN_EMAIL=admin@materialized.com
ADMIN_PASSWORD=secure-password-here

# App
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# AI Detection (optional — Gemini)
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# Shopify Integration (optional — for inventory imports)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
