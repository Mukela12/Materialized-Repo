{
  "projectSettings": {
    "framework": null
  },
  "buildCommand": "cd client && npx vite build --outDir ../dist/public",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "web": {
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install && npm run build"
    }
  }
}
